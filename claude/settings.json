{
  "alwaysThinkingEnabled": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "jq -r '.message' | xargs -I{} notify-send 'Claude Code' '{}'",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "cc-easyhooks",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
