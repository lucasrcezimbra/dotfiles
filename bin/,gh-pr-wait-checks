#!/bin/bash
set -e
set -u
set -o pipefail

use_current_branch=false
auto_plan=false

show_usage() {
  echo "Usage: $(basename "$0") [-c | <pr-id>] [--auto-plan]"
  echo "  -c          Use PR from current branch"
  echo "  --auto-plan Automatically run opencode to plan fix on CI failure"
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -c) use_current_branch=true; shift ;;
    --auto-plan) auto_plan=true; shift ;;
    -*)
      echo "Error: Unknown option: $1"
      show_usage
      exit 1
      ;;
    *)
      pr_number="$1"
      shift
      ;;
  esac
done

if $use_current_branch; then
  pr_number=$(gh pr view --json number -q .number 2>/dev/null)
  if [ -z "$pr_number" ]; then
    echo "Error: No PR found for current branch. Are you on a branch with an open PR?"
    exit 1
  fi
elif [ -z "${pr_number:-}" ]; then
  echo "Error: Missing PR ID argument."
  show_usage
  exit 1
fi

echo "Monitoring PR #${pr_number}"

poll_interval=30

while true; do
    # Get all checks for the PR
    # state values: PENDING, QUEUED, IN_PROGRESS, WAITING, SUCCESS, FAILURE, CANCELLED, TIMED_OUT, SKIPPED, etc.
    checks_json=$(gh pr checks "$pr_number" --json name,state,bucket --jq '.')

    # Count check states using bucket field (pass, fail, pending, skipping)
    total=$(echo "$checks_json" | jq 'length')
    pending=$(echo "$checks_json" | jq '[.[] | select(.bucket == "pending")] | length')
    failed=$(echo "$checks_json" | jq '[.[] | select(.bucket == "fail")] | length')
    succeeded=$(echo "$checks_json" | jq '[.[] | select(.bucket == "pass" or .bucket == "skipping")] | length')

    echo "Checks: ${succeeded}/${total} succeeded, ${failed} failed, ${pending} pending"

    if [[ "$failed" -gt 0 ]]; then
        failed_checks=$(echo "$checks_json" | jq -r '.[] | select(.bucket == "fail") | .name')
        echo "CI check(s) failed!"
        echo "Failed checks:"
        echo "$failed_checks"

        if $auto_plan; then
            notify-send --wait "CI Failed" "PR #${pr_number} has ${failed} failed check(s). Starting opencode..."
            echo "Checking out PR branch..."
            gh pr checkout "$pr_number"
            opencode --prompt "/gh-ci-plan-fix"
            exit 0
        else
            notify-send --wait "CI Failed" "PR #${pr_number} has ${failed} failed check(s)."
            exit 1
        fi
    elif [[ "$pending" -gt 0 ]]; then
        echo "Checks still pending, waiting ${poll_interval}s..."
        sleep "$poll_interval"
    else
        notify-send --wait "CI Passed" "PR #${pr_number} - All CI checks passed!"
        echo "All CI checks passed!"
        exit 0
    fi
done
