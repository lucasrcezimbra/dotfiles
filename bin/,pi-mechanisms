#!/bin/bash
set -e
set -u
set -o pipefail

HELP_TEXT='Usage: ,pi-mechanisms <path>

Find pi.* API usages in a file or directory using ripgrep.

Examples:
  ,pi-mechanisms agents/pi/extensions
  ,pi-mechanisms agents/pi/extensions/inspect.ts

Output sections:
  - Unique pi.* calls
  - Event hooks via pi.on(...)
  - Key registration/control calls
  - All pi.* calls with file/line context'

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  echo "$HELP_TEXT"
  exit 0
fi

if [[ $# -ne 1 ]]; then
  echo "$HELP_TEXT"
  exit 1
fi

if ! command -v rg >/dev/null 2>&1; then
  echo "Error: rg (ripgrep) is required but was not found in PATH" >&2
  exit 1
fi

TARGET=$1

if [[ ! -e "$TARGET" ]]; then
  echo "Error: path does not exist: $TARGET" >&2
  exit 1
fi

RG_BASE=(
  rg
  --no-heading
  --with-filename
  --line-number
  --color=never
  --pcre2
  -g '*.ts'
  -g '*.tsx'
  -g '*.js'
  -g '*.jsx'
  -g '*.mjs'
  -g '*.cjs'
  -g '*.mts'
  -g '*.cts'
)

RG_UNIQUE=(
  rg
  --no-heading
  --color=never
  --pcre2
  -g '*.ts'
  -g '*.tsx'
  -g '*.js'
  -g '*.jsx'
  -g '*.mjs'
  -g '*.cjs'
  -g '*.mts'
  -g '*.cts'
)

search() {
  local title=$1
  local pattern=$2

  echo "== $title =="
  if "${RG_BASE[@]}" "$pattern" "$TARGET"; then
    :
  else
    echo "(none)"
  fi
  echo
}

echo "Target: $TARGET"
echo

echo "== Unique pi.* calls =="
if "${RG_UNIQUE[@]}" -o '\bpi(?:\.[A-Za-z_][A-Za-z0-9_]*)+\s*\(' "$TARGET" \
  | sed -E 's/[[:space:]]*\($//' \
  | sort -u; then
  :
else
  echo "(none)"
fi
echo

search "Event hooks" '\bpi\.on\s*\('
search "Key registration/control calls" '\bpi\.(registerTool|setActiveTools|registerCommand|registerShortcut|registerFlag|sendMessage|sendUserMessage|setModel|setThinkingLevel|registerProvider|unregisterProvider|appendEntry|setSessionName|setLabel|getFlag|getAllTools|getActiveTools|getCommands|exec)\s*\('
search "All pi.* calls" '\bpi(?:\.[A-Za-z_][A-Za-z0-9_]*)+\s*\('
