#!/bin/bash
set -u
set -o pipefail

use_current_branch=false

while getopts "c" opt; do
  case $opt in
    c) use_current_branch=true ;;
    *) echo "Usage: $(basename "$0") [-c | <pr-id>]"; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

if $use_current_branch; then
  pr_number=$(gh pr view --json number -q .number 2>/dev/null)
  if [ -z "$pr_number" ]; then
    echo "Error: No PR found for current branch. Are you on a branch with an open PR?"
    exit 1
  fi
elif [ -z "${1:-}" ]; then
  echo "Error: Missing PR ID argument."
  echo "Usage: $(basename "$0") [-c | <pr-id>]"
  echo "  -c    Use PR from current branch"
  exit 1
else
  pr_number="$1"
fi

# 1. Checkout PR
echo "Checking out PR #$pr_number..."
gh pr checkout "$pr_number" || exit 1

# 2. Get Base Branch
echo "Fetching base branch info..."
BASE_BRANCH=$(gh pr view "$pr_number" --json baseRefName --jq .baseRefName)
echo "Base branch detected: $BASE_BRANCH"

# 3. Pull Base Branch
echo "Pulling changes from origin/$BASE_BRANCH..."
if git pull --no-ff origin "$BASE_BRANCH"; then
  # Success - No conflicts
  echo "Merge successful. Pushing changes..."
  git push origin "$(git branch --show-current)"
else
  # Failure - Conflicts
  echo "Conflicts detected."
  opencode --prompt /git-fix-conflicts
fi
